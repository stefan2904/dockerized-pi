{
  "lastChangelogVersion": "0.78.1",
  "theme": "nightowl",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": true,
  "shellPath": "/bin/zsh",
  "shellCommandPrefix": "setopt aliases\nsource ~/.zshrc",
  "images": {
    "autoResize": true
  },
  "editorPaddingX": 0,
  "collapseChangelog": true,
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.3-codex",
    "github-copilot/gpt-5.5",
    "github-copilot/gpt-5.3-codex",
    "github-copilot/gemini-3.1-pro-preview",
    "github-copilot/gemini-3-flash-preview",
    "github-copilot/claude-opus-4.7",
    "github-copilot/claude-sonnet-4.6"
  ],
  "packages": [
    {
      "source": "git:github.com/mitsuhiko/agent-stuff",
      "extensions": [
        "-extensions/files.ts",
        "-extensions/loop.ts",
        "-extensions/go-to-bed.ts"
      ],
      "skills": [
        "-skills/web-browser/SKILL.md",
        "-skills/openscad/SKILL.md",
        "-skills/apple-mail/SKILL.md"
      ],
      "themes": [
        "+themes/modern-dark.json",
        "+themes/nightowl.json"
      ]
    },
    "git:github.com/lucasmeijer/pi-terminal-signals",
    "npm:pi-mcp-adapter"
  ],
  "terminal": {
    "showTerminalProgress": true
  },
  "doubleEscapeAction": "tree",
  "treeFilterMode": "user-only",
  "warnings": {
    "anthropicExtraUsage": true
  }
}